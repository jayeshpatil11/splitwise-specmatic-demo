version: 3

components:
  sources:
    localContracts:
      filesystem:
        directory: .

systemUnderTest:
  service:
    definitions:
      - definition:
          source:
            $ref: "#/components/sources/localContracts"
          specs:
            - openapi/expense-sharing-api.yaml

specmatic:
  settings:
    test:
      schemaResiliencyTests: all

  license:
    path: /specmatic/specmatic-license.txt
